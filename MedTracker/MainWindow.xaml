<Window x:Class="MedTracker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MedTracker - Менеджер аптечки" Height="600" Width="900"
        MinHeight="500" MinWidth="750" WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#2C3E50">
            <StackPanel Margin="0, 30, 0, 0">
                <TextBlock Text="💊 MedTracker" Foreground="White" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,40"/>

                <Button x:Name="BtnHome" Content="Головна" Height="45" Margin="15,5" Background="#34495E" Foreground="White" FontSize="16" BorderThickness="0" Cursor="Hand" Click="BtnHome_Click"/>
                <Button x:Name="BtnInventory" Content="Список ліків" Height="45" Margin="15,5" Background="#34495E" Foreground="White" FontSize="16" BorderThickness="0" Cursor="Hand" Click="BtnInventory_Click"/>
                <Button x:Name="BtnSettings" Content="Налаштування" Height="45" Margin="15,5" Background="#34495E" Foreground="White" FontSize="16" BorderThickness="0" Cursor="Hand" Click="BtnSettings_Click"/>
            </StackPanel>
        </Border>

        <Border Grid.Column="1" Background="#ECF0F1">
            <Frame x:Name="MainFrame" NavigationUIVisibility="Hidden" Margin="20"/>
        </Border>
    </Grid>
</Window>