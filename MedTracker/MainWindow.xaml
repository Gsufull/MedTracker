<Window x:Class="MedTracker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MedTracker - Головне вікно" Height="450" Width="800"
        MinHeight="400" MinWidth="600" WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Background="#E0E0E0">
            <Label Content="Меню навігації" FontWeight="Bold" FontSize="16" Margin="10,10,10,20" HorizontalAlignment="Center"/>

            <Button x:Name="BtnHome" Content="Головна" Margin="10,5" Height="30" Click="BtnHome_Click"/>
            <Button x:Name="BtnInventory" Content="Список ліків" Margin="10,5" Height="30" Click="BtnInventory_Click"/>
            <Button x:Name="BtnSettings" Content="Налаштування" Margin="10,5" Height="30" Click="BtnSettings_Click"/>
        </StackPanel>

        <StackPanel Grid.Column="1" Margin="20">
            <TextBlock Text="Тестове додавання медикаменту" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>

            <Label Content="Назва препарату:"/>
            <TextBox x:Name="TxtMedicineName" Width="250" HorizontalAlignment="Left" Margin="5,0,0,10" Padding="2"/>

            <Label Content="Категорія (наприклад, Знеболювальні):"/>
            <TextBox x:Name="TxtCategory" Width="250" HorizontalAlignment="Left" Margin="5,0,0,20" Padding="2"/>

            <Button x:Name="BtnTestSave" Content="Зберегти дані" Width="150" Height="35" HorizontalAlignment="Left" Margin="5,0,0,0" Background="#4CAF50" Foreground="White" Click="BtnTestSave_Click"/>
        </StackPanel>
    </Grid>
</Window>