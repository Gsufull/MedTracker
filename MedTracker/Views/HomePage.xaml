<Page x:Class="MedTracker.Views.HomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="{DynamicResource Home_Title}">

    <Grid Background="{DynamicResource BgColor}" Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="{DynamicResource Home_Welcome}" Style="{DynamicResource PageTitleStyle}"/>
        <TextBlock Grid.Row="1" Text="{DynamicResource Home_Desc}" Foreground="{DynamicResource SubTextColor}" FontSize="16" Margin="0,0,0,30"/>

        <!-- Cards -->
        <Grid Grid.Row="2" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{DynamicResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="{DynamicResource Home_TotalMeds}" FontSize="16" Foreground="{DynamicResource SubTextColor}"/>
                    <TextBlock x:Name="TxtTotal" Text="0" FontSize="36" FontWeight="Bold" Foreground="{DynamicResource AccentColor}" Margin="0,10,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Style="{DynamicResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="{DynamicResource Home_Expired}" FontSize="16" Foreground="{DynamicResource SubTextColor}"/>
                    <TextBlock x:Name="TxtExpired" Text="0" FontSize="36" FontWeight="Bold" Foreground="{DynamicResource DangerColor}" Margin="0,10,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="4" Style="{DynamicResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="{DynamicResource Home_LowStock}" FontSize="16" Foreground="{DynamicResource SubTextColor}"/>
                    <TextBlock x:Name="TxtLowStock" Text="0" FontSize="36" FontWeight="Bold" Foreground="{DynamicResource TextColor}" Margin="0,10,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <StackPanel Grid.Row="3" VerticalAlignment="Top">
            <Border x:Name="BrdExpiredAlert" Background="{DynamicResource DangerColor}" CornerRadius="8" Padding="15" Margin="0,0,0,20" Visibility="Collapsed">
                <TextBlock Text="{DynamicResource Home_ExpiredAlert}" Foreground="White" FontWeight="SemiBold" FontSize="14"/>
            </Border>
            
            <Button Content="{DynamicResource Home_GoInventory}" Style="{DynamicResource ActionBtnStyle}" Width="250" HorizontalAlignment="Left" Click="BtnGoInventory_Click"/>
        </StackPanel>
    </Grid>
</Page>
