<Page x:Class="MedTracker.Views.InventoryPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:MedTracker.ViewModels"
      Title="{DynamicResource Inv_Title}">

    <Page.DataContext>
        <vm:InventoryViewModel/>
    </Page.DataContext>

    <Grid Background="{DynamicResource BgColor}" Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="6.5*"/>
            <ColumnDefinition Width="20"/>
            <ColumnDefinition Width="3.5*"/>
        </Grid.ColumnDefinitions>

        <!-- Left Side: DataGrid -->
        <Border Grid.Column="0" Style="{DynamicResource CardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <TextBlock Grid.Row="0" Text="{DynamicResource Inv_Title}" Style="{DynamicResource PageTitleStyle}"/>

                <DataGrid Grid.Row="1" ItemsSource="{Binding Medicines}" SelectedItem="{Binding SelectedMedicine}" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" x:Name="DgMedicines">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="{DynamicResource Inv_Name}" Binding="{Binding Name}" Width="*"/>
                        <DataGridTextColumn Header="{DynamicResource Inv_Category}" Binding="{Binding Category}" Width="1.5*"/>
                        <DataGridTextColumn Header="{DynamicResource Inv_Quantity}" Binding="{Binding Quantity}" Width="60"/>
                        <DataGridTextColumn Header="{DynamicResource Inv_Expiry}" Binding="{Binding ExpiryDate, StringFormat=dd.MM.yyyy}" Width="100"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- Right Side: Details Form -->
        <Border Grid.Column="2" Style="{DynamicResource CardStyle}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="{DynamicResource Inv_Details}" Style="{DynamicResource PageTitleStyle}" FontSize="20"/>

                    <TextBlock Text="{DynamicResource Inv_NameLabel}" Style="{DynamicResource LabelStyle}"/>
                    <TextBox Text="{Binding CurrentMedicine.Name, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"/>

                    <TextBlock Text="{DynamicResource Inv_CategoryLabel}" Style="{DynamicResource LabelStyle}"/>
                    <TextBox Text="{Binding CurrentMedicine.Category, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"/>

                    <TextBlock Text="{DynamicResource Inv_QuantityLabel}" Style="{DynamicResource LabelStyle}"/>
                    <TextBox Text="{Binding CurrentMedicine.Quantity, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"/>

                    <TextBlock Text="{DynamicResource Inv_ExpiryLabel}" Style="{DynamicResource LabelStyle}"/>
                    <DatePicker SelectedDate="{Binding CurrentMedicine.ExpiryDate, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Text="{DynamicResource Inv_NotesLabel}" Style="{DynamicResource LabelStyle}"/>
                    <TextBox Text="{Binding CurrentMedicine.Notes, UpdateSourceTrigger=PropertyChanged}" TextWrapping="Wrap" AcceptsReturn="True" Height="80"/>

                    <StackPanel Margin="0,20,0,0">
                        <Button Content="{DynamicResource Inv_Save}" Command="{Binding SaveCommand}" Style="{DynamicResource ActionBtnStyle}" Margin="0,0,0,10"/>
                        <Button Content="{DynamicResource Inv_Clear}" Command="{Binding ClearCommand}" Style="{DynamicResource NeutralBtnStyle}" Margin="0,0,0,10"/>
                        <Button Content="{DynamicResource Inv_Delete}" Command="{Binding DeleteCommand}" Style="{DynamicResource DangerBtnStyle}"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Page>