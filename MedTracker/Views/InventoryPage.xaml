<Page x:Class="MedTracker.Views.InventoryPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:MedTracker.ViewModels"
      Title="InventoryPage">

    <Page.DataContext>
        <vm:InventoryViewModel/>
    </Page.DataContext>

    <Grid Background="{DynamicResource BgColor}" Margin="10">
        <StackPanel>
            <TextBlock Text="Список медикаментів" FontSize="22" FontWeight="Bold" 
                       Foreground="{DynamicResource TextColor}" Margin="0,0,0,15"/>

            <DataGrid ItemsSource="{Binding Medicines}" AutoGenerateColumns="False" 
                      CanUserAddRows="False" 
                      Background="{DynamicResource PanelColor}" 
                      RowBackground="{DynamicResource PanelColor}" 
                      Foreground="{DynamicResource TextColor}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Назва" Binding="{Binding Name}" Width="*"/>
                    <DataGridTextColumn Header="Категорія" Binding="{Binding Category}" Width="*"/>
                    <DataGridTextColumn Header="Кількість" Binding="{Binding Quantity}" Width="100"/>
                </DataGrid.Columns>
            </DataGrid>
        </StackPanel>
    </Grid>
</Page>